  "keyFeatures": [
    "End-to-end encrypted photo storage with face detection and semantic search",
    "2FA authenticator with cloud backup and multi-device sync",
    "Secure document locker with emergency access",
    "Private album sharing with collaborative features",
    "Self-hostable server with Docker support",
    "Cross-platform clients (iOS, Android, Web, Desktop)",
    "CLI tool for automated backups and exports",
    "Family plans with shared storage",
    "Open source and externally audited cryptography"
  ],
  "publicApiSurface": [
    "POST /users/ott - Request one-time token for authentication",
    "POST /users/verify-email - Verify email with OTT",
    "GET /users - Get current user details",
    "POST /files - Upload encrypted files",
    "GET /files/download - Download encrypted files",
    "POST /collections - Create collection (album/folder)",
    "POST /collections/share - Share collection with users",
    "GET /collections/diff - Sync collection changes",
    "POST /authenticator/entity - Add 2FA entity",
    "GET /authenticator/entity/diff - Sync 2FA changes",
    "GET /billing/plans - Get subscription plans",
    "POST /billing/subscription - Create subscription",
    "POST /family/invite - Invite family members",
    "POST /cast/register-device - Register casting device",
    "POST /public-collection/create - Create public share link",
    "Mobile App: Ente Photos (Flutter) - io.ente.photos",
    "Mobile App: Ente Auth (Flutter) - io.ente.auth",
    "Mobile App: Ente Locker (Flutter) - io.ente.locker",
    "Desktop App: Electron-based (Windows, macOS, Linux)",
    "Web Apps: photos, auth, accounts, cast, payments",
    "CLI: ente account, ente export, ente auth-decrypt"
  ]
